generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Cliente {
  MICHELIN
  CONTINENTAL
}

enum TipoEvento {
  CNTI
  CNTO
  CNTS
}

enum FuenteEvento {
  IMPORTACION
  MANUAL
}

enum Pais {
  ES
  PT
}

enum Rol {
  ADMIN
  PLATAFORMA
}

model Bancal {
  id                 String      @id @default(cuid())
  codigo             String      @unique
  cliente            Cliente
  plataformaActualId String?
  ultimaLectura      DateTime?
  ultimoTipoEvento   TipoEvento?
  activo             Boolean     @default(true)
  createdAt          DateTime    @default(now())

  plataformaActual   Plataforma? @relation(fields: [plataformaActualId], references: [id])
  eventos            Evento[]
  baja               BancalBaja?

  @@map("bancales")
}

model BancalBaja {
  id        String   @id @default(cuid())
  bancalId  String   @unique
  fechaBaja DateTime @default(now())

  bancal    Bancal   @relation(fields: [bancalId], references: [id])

  @@map("bancales_baja")
}

model Plataforma {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nombre    String
  pais      Pais
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())

  bancalesActuales Bancal[]
  eventos          Evento[]
  usuario          Usuario?

  @@map("plataformas")
}

model Usuario {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  role         Rol        @default(PLATAFORMA)
  plataformaId String?    @unique
  plataforma   Plataforma? @relation(fields: [plataformaId], references: [id])
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@map("usuarios")
}

model Evento {
  id           String       @id @default(cuid())
  bancalId     String
  plataformaId String
  tipo         TipoEvento
  lectura      DateTime
  usuario      String
  observaciones String?
  fuente       FuenteEvento
  createdAt    DateTime     @default(now())

  bancal       Bancal       @relation(fields: [bancalId], references: [id])
  plataforma   Plataforma   @relation(fields: [plataformaId], references: [id])

  @@index([plataformaId, tipo, lectura])
  @@index([bancalId, lectura])
  @@map("eventos")
}

model Configuracion {
  id        String   @id @default(cuid())
  clave     String   @unique
  valor     String
  updatedAt DateTime @updatedAt

  @@map("configuracion")
}
